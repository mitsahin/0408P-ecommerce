  },
  "variable": [
    { "key": "baseUrl", "value": "https://workintech-fe-ecommerce.onrender.com" },
    { "key": "token", "value": "" },
    { "key": "userEmail", "value": "customer@commerce.com" },
    { "key": "customerRoleId", "value": "1" },
    { "key": "storeRoleId", "value": "2" },
    { "key": "addressId", "value": "" },
    { "key": "cardId", "value": "" },
    { "key": "productId", "value": "322" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Get Roles",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/roles",
              "host": ["{{baseUrl}}"],
              "path": ["roles"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const roles = pm.response.json();",
                  "const customer = roles.find((role) => role.code === 'customer');",
                  "const store = roles.find((role) => role.code === 'store');",
                  "if (customer) pm.collectionVariables.set('customerRoleId', String(customer.id));",
                  "if (store) pm.collectionVariables.set('storeRoleId', String(store.id));"
                ]
              }
            }
          ]
        },
        {
          "name": "Signup (Customer/Admin Payload)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jane Doe\",\n  \"email\": \"jane.doe+{{$timestamp}}@example.com\",\n  \"password\": \"Test1234!\",\n  \"role_id\": {{customerRoleId}}\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/signup",
              "host": ["{{baseUrl}}"],
              "path": ["signup"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 201 or 200', function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Signup (Store Payload)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Store Owner\",\n  \"email\": \"store.owner+{{$timestamp}}@example.com\",\n  \"password\": \"Test1234!\",\n  \"role_id\": {{storeRoleId}},\n  \"store\": {\n    \"name\": \"Bandage Store\",\n    \"phone\": \"05551234567\",\n    \"tax_no\": \"T1234V123456\",\n    \"bank_account\": \"TR000000000000000000000000\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/signup",
              "host": ["{{baseUrl}}"],
              "path": ["signup"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 201 or 200', function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Login (Customer)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"customer@commerce.com\",\n  \"password\": \"123456\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/login",
              "host": ["{{baseUrl}}"],
              "path": ["login"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const data = pm.response.json();",
                  "pm.test('token is returned', function () {",
                  "  pm.expect(data.token).to.be.a('string').and.not.empty;",
                  "});",
                  "if (data.token) pm.collectionVariables.set('token', data.token);",
                  "const email = data?.user?.email || data?.email || '';",
                  "if (email) pm.collectionVariables.set('userEmail', email);"
                ]
              }
            }
          ]
        },
        {
          "name": "Verify Token",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "{{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/verify",
              "host": ["{{baseUrl}}"],
              "path": ["verify"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const data = pm.response.json();",
                  "const user = data.user || data;",
                  "pm.test('user exists', function () {",
                  "  pm.expect(user).to.exist;",
                  "});",
                  "if (data.token) pm.collectionVariables.set('token', data.token);",
                  "if (user?.email) pm.collectionVariables.set('userEmail', user.email);"
                ]
              }
            }
          ]
        }
      ]
    },
