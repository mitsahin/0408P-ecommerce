        },
        {
          "name": "Get Products (Category + Filter + Sort)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/products?category=2&filter=siyah&sort=price:desc",
              "host": ["{{baseUrl}}"],
              "path": ["products"],
              "query": [
                { "key": "category", "value": "2" },
                { "key": "filter", "value": "siyah" },
                { "key": "sort", "value": "price:desc" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "const list = data.products || data;",
                  "if (Array.isArray(list) && list.length > 0) {",
                  "  pm.collectionVariables.set('productId', String(list[0].id));",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Products (Pagination Page 1)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/products?limit=25&offset=0",
              "host": ["{{baseUrl}}"],
              "path": ["products"],
              "query": [
                { "key": "limit", "value": "25" },
                { "key": "offset", "value": "0" }
              ]
            }
          }
        },
        {
          "name": "Get Products (Pagination Page 2)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/products?limit=25&offset=25",
              "host": ["{{baseUrl}}"],
              "path": ["products"],
              "query": [
                { "key": "limit", "value": "25" },
                { "key": "offset", "value": "25" }
              ]
            }
          }
        },
        {
          "name": "Get Products (Pagination Page 3)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/products?limit=25&offset=50",
              "host": ["{{baseUrl}}"],
              "path": ["products"],
              "query": [
                { "key": "limit", "value": "25" },
                { "key": "offset", "value": "50" }
              ]
            }
          }
        },
        {
          "name": "Get Product Detail",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/products/{{productId}}",
              "host": ["{{baseUrl}}"],
              "path": ["products", "{{productId}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const data = pm.response.json();",
                  "pm.test('product has id and name', function () {",
                  "  pm.expect(data.id).to.exist;",
                  "  pm.expect(data.name || data.title).to.exist;",
                  "});"
                ]
              }
            }
          ]
        }
      ]
